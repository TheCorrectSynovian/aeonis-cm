{
	"schema_version": 1,
	"quilt_loader": {
		"group": "com.qc.aeonis",
	"id": "aeonis",
		"version": "${version}",
		"metadata": {
			"name": "Aeonis",
			"description": "Aeonis is a multi-system Minecraft framework combining transformation mechanics, AI-assisted command systems, custom dimensions, unique mobs, and advanced rendering enhancements into one unified experience.",
			"contributors": {
				"Quantum_Creeper": "Author"
			},
			"contact": {
				"homepage": "https://www.youtube.com/@quantumcreeper",
				"sources": "https://github.com/TeamQC-MC/Aeonis-mod",
				"issues": "https://github.com/TeamQC-MC/Aeonis-mod/issues"
			},
			"license": "MIT",
			"icon": "assets/aeonis-manager/icon.png"
		},
		"intermediate_mappings": "net.fabricmc:intermediary",
		"entrypoints": {
			"init": [
				{
					"value": "com.qc.aeonis.AeonisManager",
					"adapter": "kotlin"
				}
			],
			"client_init": [
				{
					"value": "com.qc.aeonis.AeonisManagerClient",
					"adapter": "kotlin"
				}
			]
		},
		"depends": [
			{
				"id": "quilt_loader",
				"versions": ">=0.17.0"
			},
			{
				"id": "quilted_fabric_api",
				"versions": "*"
			},
			{
				"id": "minecraft",
				"versions": ">=26.1 <26.2"
			},
			{
				"id": "java",
				"versions": ">=25"
			}
		],
		"provides": [
			{
				"id": "aeonis",
				"version": "${version}"
			}
		]
	},
	"mixin": [
		"aeonis-manager.mixins.json",
		"aeonis-manager.client.mixins.json"
	]
}
