{
	"schemaVersion": 1,
	"id": "aeonis",
	"version": "${version}",
	"name": "Aeonis",
	"description": "Aeonis is an advanced Fabric framework mod focused on gameplay systems, AI features, and cinematic world content.\n\nCore Systems:\n• Player and mob transformations\n• AI-assisted command/control systems\n• Custom dimensions and progression hooks\n• Unique mobs with custom animations\n• Enhanced rendering and visual effects\n• Utility, combat, and framework tooling\n\nProject Links: Website, GitHub, Releases, Issues.",
	"authors": [
		"Quantum_Creeper"
	],
	"contact": {
		"homepage": "https://aeonis.prenxy.app",
		"sources": "https://github.com/TeamQC-MC/aeonis-cm",
		"issues": "https://github.com/TeamQC-MC/aeonis-cm/issues"
	},
	"license": "MIT",
	"icon": "assets/aeonis-manager/icon.png",
	"environment": "*",
	"custom": {
		"modmenu": {
			"badges": ["library"],
			"links": {
				"modmenu.homepage": "https://aeonis.prenxy.app",
				"modmenu.github": "https://github.com/TeamQC-MC/aeonis-cm",
				"modmenu.sources": "https://github.com/TeamQC-MC/aeonis-cm",
				"modmenu.issues": "https://github.com/TeamQC-MC/aeonis-cm/issues",
				"modmenu.releases": "https://github.com/TeamQC-MC/aeonis-cm/releases",
				"modmenu.youtube": "https://www.youtube.com/@quantumcreeper"
			}
		}
	},
	"entrypoints": {
		"main": [
			{
				"value": "com.qc.aeonis.AeonisManager",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.qc.aeonis.AeonisManagerClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "com.qc.aeonis.AeonisManagerDataGenerator",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "com.qc.aeonis.integration.modmenu.AeonisModMenuIntegration",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"aeonis-manager.mixins.json",
		{
			"config": "aeonis-manager.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1 <26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
